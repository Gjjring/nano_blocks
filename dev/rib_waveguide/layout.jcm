Layout2D {
  Name = "Rib Waveguide"
  UnitOfLength = 1e-06
  
  MeshOptions {
    MaximumSideLength = 0.5
  }
  Objects {    
    Parallelogram {
      Name = "ComputationalDomain"
      Width = 3
      Height = 5
      DomainId = 1
      Port = South
      Priority = ComputationalDomain
      Boundary {
        Class = Transparent
      }
    }
    
    Parallelogram {
      Name = "Substrate"
      Width = 3
      Height = 1
      DomainId = 3
      Port = South
      #GlobalPosition = [0 -1]
    }
    
    Parallelogram {
      Name = "Waveguide"
      Width = 0.3
      Height = 3
      DomainId = 2
      Port = South
      Alignment {
        Displacement = [ 0 0]
        Orientation = AntiParallel
        Parent {
          Domain = "Substrate"
          Port = North
        }
      }
    }
    
  }
}