Layout2D {  
  UnitOfLength = 1e-9
  BoundaryConditions {
    Boundary {
      Class = Transparent
      Direction = X
      
    }
    
    Boundary {
      Class = Mirror
      Direction = -X
      
    }
    Boundary {
      Class = Periodic
      Direction = [-Y Y]
    }
  }
  Objects {
    Parallelogram {
      Name = "CD"
      DomainId = 1
      Priority = ComputationalDomain
      Height = 10.
      Width = 600.
      Port = West
      GlobalPosition = [600., 0]
      MeshOptions {
        MaximumSideLength = 20.
      }
    }
    Parallelogram {
      DomainId = 2
      Port = West
      Width = 150.
      Height = 10.
      MeshOptions {
        MaximumSideLength = 10.
      }
      Alignment {
        Displacement = [0 0]
        Orientation = Parallel
        Parent {
          Domain = "CD"
          Port = West
        }
      }
    }
  }
  
}