<?
keys['wg_displacement_left_reversed'] = -1*keys['wg_displacement_left']
keys['wg_displacement_right_reversed'] = -1*keys['wg_displacement_right']
?>
Layout2D {
  Name = "Waveguide_Filter"
  UnitOfLength = 1e-06


  Objects {
    Parallelogram {
